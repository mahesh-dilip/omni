# Firebase web app config (Project settings -> Your apps -> Web app).
# These are public client identifiers, protected by Firebase Security Rules,
# but are kept here so the app can target any Firebase project without code edits.
REACT_APP_FIREBASE_API_KEY=your-firebase-web-api-key
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=000000000000
REACT_APP_FIREBASE_APP_ID=1:000000000000:web:xxxxxxxxxxxxxxxx
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Base URL of the Express backend. Defaults to http://localhost:3001 if unset.
REACT_APP_API_URL=http://localhost:3001
