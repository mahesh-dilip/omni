# Google Gemini API key (https://aistudio.google.com/app/apikey).
# SECRET — never commit the real value.
GEMINI_API_KEY=your-gemini-api-key

# Port the Express server listens on. Defaults to 3001 if unset.
PORT=3001

# Firebase Admin credentials are loaded from backend/serviceAccountKey.json
# (Project settings -> Service accounts -> Generate new private key).
# That file is SECRET and is git-ignored — download your own and place it at
# backend/serviceAccountKey.json. Do NOT commit it.
